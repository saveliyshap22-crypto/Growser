<Window x:Class="Chroma.Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Chroma Browser"
        Width="1320"
        Height="850"
        MinWidth="860"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Icon="Resources/Chroma.png"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleRow" Height="45" />
            <RowDefinition x:Name="ToolbarRow" Height="62" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#A91C1F25"
                BorderBrush="#24FFFFFF"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Width="27" Height="27" Margin="9" Source="Resources/Chroma.png" IsHitTestVisible="False" />

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="TabStrip"
                             Grid.Column="0"
                             Height="39"
                             Margin="0,4,4,2"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="TabStrip_SelectionChanged"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="TabStrip_PreviewMouseMove"
                             Drop="TabStrip_Drop">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="MinWidth" Value="108" />
                                <Setter Property="MaxWidth" Value="230" />
                                <Setter Property="Height" Value="36" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,4,0" />
                                <Setter Property="Background" Value="#321FFFFFFF" />
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Setter Property="BorderBrush" Value="#22FFFFFF" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="TabSurface"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="18">
                                                <ContentPresenter Margin="2" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TabSurface" Property="Background" Value="#8740444D" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="TabSurface" Property="Background" Value="#E13A3E47" />
                                                    <Setter TargetName="TabSurface" Property="BorderBrush" Value="#5AFFFFFF" />
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <Button Grid.Column="1" Margin="2,4" Style="{StaticResource IconButton}" Click="NewTab_Click" ToolTip="Новая вкладка (Ctrl+T)" Content="&#xE710;" />
                </Grid>

                <Border x:Name="PrivateBadge" Grid.Column="2" Margin="6,7" Padding="13,5" CornerRadius="16" Background="#663B4050" BorderBrush="#35FFFFFF" BorderThickness="1" Visibility="Collapsed">
                    <TextBlock FontSize="12" Foreground="{StaticResource MutedTextBrush}" Text="ИНКОГНИТО" />
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="46" Height="45" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Click="Minimize_Click" Content="&#xE921;" FontFamily="Segoe Fluent Icons" />
                    <Button Width="46" Height="45" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Click="Maximize_Click" Content="&#xE922;" FontFamily="Segoe Fluent Icons" />
                    <Button Width="48" Height="45" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Click="Close_Click" Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="8,4,8,6" Padding="8,6" Background="#D72A2E36" BorderBrush="#38FFFFFF" BorderThickness="1" CornerRadius="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BackButton" Style="{StaticResource IconButton}" Click="Back_Click" ToolTip="Назад (Alt+←)" Content="&#xE72B;" />
                    <Button x:Name="ForwardButton" Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Forward_Click" ToolTip="Вперёд (Alt+→)" Content="&#xE72A;" />
                    <Button x:Name="ReloadButton" Margin="4,0,8,0" Style="{StaticResource IconButton}" Click="Reload_Click" ToolTip="Обновить (Ctrl+R)" Content="&#xE72C;" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <TextBox x:Name="AddressBar"
                             Height="44"
                             Style="{StaticResource GlassTextBox}"
                             FontSize="14"
                             TextChanged="AddressBar_TextChanged"
                             GotKeyboardFocus="AddressBar_GotKeyboardFocus"
                             PreviewKeyDown="AddressBar_PreviewKeyDown" />
                    <Popup x:Name="SuggestionsPopup"
                           PlacementTarget="{Binding ElementName=AddressBar}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Width="620" MaxHeight="360" Margin="0,8,0,0" Padding="6" Background="#FA202329" BorderBrush="#4AFFFFFF" BorderThickness="1" CornerRadius="22">
                            <ListBox x:Name="SuggestionsList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MouseDoubleClick="SuggestionsList_MouseDoubleClick"
                                     DisplayMemberPath="Display" />
                        </Border>
                    </Popup>
                </Grid>

                <StackPanel Grid.Column="2" Margin="8,0,0,0" Orientation="Horizontal">
                    <Button x:Name="BookmarkButton" Style="{StaticResource IconButton}" Click="Bookmark_Click" ToolTip="Добавить в закладки (Ctrl+D)" Content="&#xE734;" />
                    <Button x:Name="ShieldButton" MinWidth="44" Width="Auto" Margin="4,0,0,0" Style="{StaticResource GlassButton}" Click="Shield_Click" ToolTip="Защита Chroma">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xEA18;" />
                            <TextBlock x:Name="BlockedCountText" Margin="6,0,0,0" Text="0" />
                        </StackPanel>
                    </Button>
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Ai_Click" ToolTip="ИИ-панель" Content="&#xE99A;" />
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Downloads_Click" ToolTip="Загрузки (Ctrl+J)" Content="&#xE896;" />
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Menu_Click" ToolTip="Меню" Content="&#xE712;" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="AiColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="8,0,8,8" Background="#111318" BorderBrush="#25FFFFFF" BorderThickness="1" CornerRadius="24" ClipToBounds="True">
                <ContentControl x:Name="BrowserContent" />
            </Border>

            <Border x:Name="AiPanel" Grid.Column="1" Margin="0,0,8,8" Background="#F21D2026" BorderBrush="#3DFFFFFF" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GridSplitter Grid.Column="0" Width="6" HorizontalAlignment="Stretch" Background="Transparent" DragDelta="AiSplitter_DragDelta" DragCompleted="AiSplitter_DragCompleted" />
                    <Grid Grid.Column="1" Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="30" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="AiProviderBox" Height="36" SelectionChanged="AiProviderBox_SelectionChanged" DisplayMemberPath="Name" />
                            <Button Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="AiClose_Click" Content="&#xE8BB;" />
                        </Grid>
                        <WrapPanel Grid.Row="1" Margin="0,6,0,8">
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiSummarize_Click" Content="Пересказать" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiExplain_Click" Content="Объяснить" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiTranslate_Click" Content="Перевести" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiSelection_Click" Content="По выделению" />
                        </WrapPanel>
                        <wv2:WebView2 x:Name="AiWebView" Grid.Row="2" />
                        <TextBlock x:Name="AiStatus" Grid.Row="3" Margin="4,7,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="ИИ работает через официальный веб-интерфейс выбранного сервиса" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
