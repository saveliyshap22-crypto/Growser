<Window x:Class="Chroma.Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Chroma Browser"
        Width="1380"
        Height="900"
        MinWidth="860"
        MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Icon="Resources/Chroma.png"
        Initialized="Experience_Initialized"
        Loaded="Window_Loaded"
        Activated="Window_Activated"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                                  CornerRadius="18"
                                  GlassFrameThickness="0"
                                  ResizeBorderThickness="7"
                                  UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid" Background="{DynamicResource WindowBrush}" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleRow" Height="50" />
            <RowDefinition x:Name="ToolbarRow" Height="68" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource GlassStrongBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="7,5,5,5" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="AppLogoSurface"
                            Width="38" Height="38"
                            CornerRadius="{DynamicResource TabCornerRadius}"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource AccentMediumBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Border Height="1" Margin="7,0" VerticalAlignment="Top" Background="{DynamicResource GlassHighlightBrush}" />
                            <Image Width="27" Height="27" Source="Resources/Chroma.png" IsHitTestVisible="False" />
                        </Grid>
                    </Border>

                    <Border x:Name="MediaPill"
                            Width="248" Height="40"
                            Visibility="Collapsed"
                            Background="{DynamicResource GlassBrush}"
                            BorderBrush="{DynamicResource AccentMediumBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource PillCornerRadius}"
                            ClipToBounds="True"
                            MouseLeftButtonUp="MediaPill_Click"
                            ToolTip="Нажмите, чтобы открыть вкладку с музыкой">
                        <Grid Margin="5,0,4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <Border Width="28" Height="28" CornerRadius="{DynamicResource TabCornerRadius}"
                                    Background="{DynamicResource AccentSoftBrush}">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons" FontSize="13"
                                           Foreground="{DynamicResource AccentTextBrush}" Text="&#xE8D6;" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="7,3,5,3" VerticalAlignment="Center">
                                <TextBlock x:Name="MediaTitleText" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           Text="Сейчас играет" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="MediaArtistText" Margin="0,1,0,0" FontSize="9.5"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Сайт" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button x:Name="MediaPlayPauseButton" Grid.Column="2" Width="29" Height="29"
                                    Style="{StaticResource IconButton}" Click="MediaPlayPause_Click"
                                    Content="&#xE769;" ToolTip="Пауза" />
                            <Button x:Name="MediaMuteButton" Grid.Column="3" Width="29" Height="29"
                                    Style="{StaticResource IconButton}" Click="MediaMute_Click"
                                    Content="&#xE767;" ToolTip="Выключить звук" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="44" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="TabStrip"
                             Grid.Column="0"
                             Height="42"
                             Margin="0,4,4,3"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="TabStrip_SelectionChanged"
                             PreviewMouseWheel="TabStrip_PreviewMouseWheel"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="TabStrip_PreviewMouseMove"
                             Drop="TabStrip_Drop">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Width" Value="180" />
                                <Setter Property="MinWidth" Value="72" />
                                <Setter Property="MaxWidth" Value="240" />
                                <Setter Property="Height" Value="39" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,5,0" />
                                <Setter Property="Background" Value="{DynamicResource GlassBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="TabSurface"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="{DynamicResource TabCornerRadius}"
                                                    ClipToBounds="True"
                                                    Opacity="1"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <TranslateTransform Y="0" />
                                                </Border.RenderTransform>
                                                <Grid>
                                                    <Border Height="1" Margin="10,0" VerticalAlignment="Top"
                                                            Background="{DynamicResource GlassHighlightBrush}" />
                                                    <Border x:Name="ActiveLine" Width="30" Height="2" Margin="0,0,0,2"
                                                            VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                            CornerRadius="1" Background="{DynamicResource AccentBrush}"
                                                            Visibility="Collapsed" />
                                                    <ContentPresenter Margin="2" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="TabSurface"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             From="0" To="1" Duration="0:0:0.16" />
                                                            <DoubleAnimation Storyboard.TargetName="TabSurface"
                                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                             From="6" To="0" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TabSurface" Property="Background" Value="{DynamicResource GlassHoverBrush}" />
                                                    <Setter TargetName="TabSurface" Property="BorderBrush" Value="{DynamicResource AccentMediumBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="TabSurface" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                    <Setter TargetName="TabSurface" Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}" />
                                                    <Setter TargetName="ActiveLine" Property="Visibility" Value="Visible" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button x:Name="TabOverviewButton" Grid.Column="1" Margin="2,4" Style="{StaticResource IconButton}"
                            Click="TabOverview_Click" ToolTip="Все вкладки">
                        <Grid>
                            <TextBlock FontFamily="Segoe Fluent Icons" FontSize="15" Text="&#xE8A9;" />
                            <Border MinWidth="17" Height="17" Margin="20,-17,-9,0" Padding="4,0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    CornerRadius="9" Background="{DynamicResource AccentStrongBrush}">
                                <TextBlock x:Name="TabCountText" Foreground="{DynamicResource AccentForegroundBrush}"
                                           FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" Text="1"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Button>
                    <Button Grid.Column="2" Margin="2,4" Style="{StaticResource IconButton}" Click="NewTab_Click"
                            ToolTip="Новая вкладка (Ctrl+T)" Content="&#xE710;" />
                </Grid>

                <Border x:Name="PrivateBadge" Grid.Column="2" Margin="6,8" Padding="13,5"
                        CornerRadius="{DynamicResource PillCornerRadius}"
                        Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentMediumBrush}"
                        BorderThickness="1" Visibility="Collapsed">
                    <TextBlock FontSize="12" Foreground="{DynamicResource AccentTextBrush}" Text="ИНКОГНИТО" />
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="46" Height="50" Style="{StaticResource WindowCaptionButton}" Click="Minimize_Click" Content="&#xE921;" />
                    <Button Width="46" Height="50" Style="{StaticResource WindowCaptionButton}" Click="Maximize_Click" Content="&#xE922;" />
                    <Button Width="50" Height="50" Style="{StaticResource WindowCloseButton}" Click="Close_Click" Content="&#xE8BB;" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="ToolbarSurface" Grid.Row="1" Margin="10,6,10,8" Padding="9,7"
                Background="{DynamicResource GlassStrongBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                CornerRadius="{DynamicResource PanelCornerRadius}" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BackButton" Style="{StaticResource IconButton}" Click="Back_Click" ToolTip="Назад (Alt+←)" Content="&#xE72B;" />
                    <Button x:Name="ForwardButton" Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Forward_Click" ToolTip="Вперёд (Alt+→)" Content="&#xE72A;" />
                    <Button x:Name="ReloadButton" Margin="4,0,9,0" Style="{StaticResource IconButton}" Click="Reload_Click" ToolTip="Обновить (Ctrl+R)" Content="&#xE72C;" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <TextBox x:Name="AddressBar" Height="48" Style="{StaticResource GlassTextBox}" FontSize="14"
                             TextChanged="AddressBar_TextChanged" GotKeyboardFocus="AddressBar_GotKeyboardFocus"
                             PreviewKeyDown="AddressBar_PreviewKeyDown" />
                    <Popup x:Name="SuggestionsPopup" PlacementTarget="{Binding ElementName=AddressBar}" Placement="Bottom"
                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Width="640" MaxHeight="370" Margin="0,9,0,0" Padding="7"
                                Background="{DynamicResource MenuSurfaceBrush}"
                                BorderBrush="{DynamicResource AccentMediumBrush}" BorderThickness="1"
                                CornerRadius="{DynamicResource PanelCornerRadius}">
                            <ListBox x:Name="SuggestionsList" Background="Transparent" BorderThickness="0"
                                     MouseDoubleClick="SuggestionsList_MouseDoubleClick" DisplayMemberPath="Display" />
                        </Border>
                    </Popup>
                </Grid>

                <StackPanel Grid.Column="2" Margin="9,0,0,0" Orientation="Horizontal">
                    <Button x:Name="BookmarkButton" Style="{StaticResource IconButton}" Click="Bookmark_Click" ToolTip="Добавить в закладки (Ctrl+D)" Content="&#xE734;" />
                    <Button x:Name="ShieldButton" MinWidth="44" Width="Auto" Margin="4,0,0,0" Style="{StaticResource GlassButton}" Click="Shield_Click" ToolTip="Защита Chroma">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="{DynamicResource AccentTextBrush}" FontFamily="Segoe Fluent Icons" Text="&#xEA18;" />
                            <TextBlock x:Name="BlockedCountText" Margin="6,0,0,0" Text="0" />
                        </StackPanel>
                    </Button>
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Ai_Click" ToolTip="ИИ-панель" Content="&#xE99A;" />
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Downloads_Click" ToolTip="Загрузки (Ctrl+J)" Content="&#xE896;" />
                    <Button Margin="4,0,0,0" Style="{StaticResource IconButton}" Click="Menu_Click" ToolTip="Меню" Content="&#xE712;" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="AiColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border x:Name="BrowserHostBorder" Grid.Column="0" Margin="10,0,10,10"
                    Background="{DynamicResource ContentSurfaceBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="1" CornerRadius="{DynamicResource PanelCornerRadius}" ClipToBounds="True">
                <ContentControl x:Name="BrowserContent" />
            </Border>

            <Border x:Name="AiPanel" Grid.Column="1" Margin="0,0,10,10"
                    Background="{DynamicResource GlassStrongBrush}"
                    BorderBrush="{DynamicResource AccentMediumBrush}" BorderThickness="1"
                    CornerRadius="{DynamicResource PanelCornerRadius}" Visibility="Collapsed" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <GridSplitter Grid.Column="0" Width="6" HorizontalAlignment="Stretch" Background="Transparent"
                                  DragDelta="AiSplitter_DragDelta" DragCompleted="AiSplitter_DragCompleted" />
                    <Grid Grid.Column="1" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="1,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Chroma AI" />
                                <TextBlock Margin="0,2,0,5" FontSize="10.5" Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Подготовьте запрос и вставьте его в официальный чат" TextTrimming="CharacterEllipsis" />
                                <ComboBox x:Name="AiProviderBox" Height="38" SelectionChanged="AiProviderBox_SelectionChanged" DisplayMemberPath="Name" />
                            </StackPanel>
                            <Button Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Top"
                                    Style="{StaticResource IconButton}" Click="AiClose_Click" ToolTip="Закрыть AI" Content="&#xE8BB;" />
                        </Grid>

                        <Border Grid.Row="1" Margin="0,8,0,8" Padding="10"
                                Background="{DynamicResource GlassBrush}" BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1" CornerRadius="{DynamicResource ControlCornerRadius}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox x:Name="AiPromptBox" MinHeight="74" MaxHeight="150" Padding="8"
                                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}"
                                         PreviewKeyDown="AiPromptBox_PreviewKeyDown"
                                         ToolTip="Введите запрос. Ctrl+Enter — вставить его в открытый AI-чат." />
                                <Grid Grid.Row="1" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="AiIncludeContextCheck" Content="Добавить текущую страницу"
                                              Checked="AiContext_Changed" Unchecked="AiContext_Changed" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Margin="4,0,0,0" Style="{StaticResource GlassButton}" Click="AiCopyPrompt_Click" Content="Копировать" />
                                        <Button Margin="4,0,0,0" Style="{StaticResource AccentButton}" Click="AiPasteToChat_Click" Content="Вставить" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <WrapPanel Grid.Row="2" Margin="0,0,0,9">
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiQuickPrompt_Click" Tag="Кратко и структурированно перескажи текущую страницу на русском языке. Выдели главные факты и выводы." Content="Пересказать" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiQuickPrompt_Click" Tag="Объясни содержание текущей страницы простыми словами. Отдельно укажи важные детали и спорные утверждения." Content="Объяснить" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiQuickPrompt_Click" Tag="Переведи содержимое текущей страницы на русский язык, сохраняя структуру и термины." Content="Перевести" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiQuickPrompt_Click" Tag="Проанализируй выделенный текст или код, найди ошибки и предложи конкретные исправления." Content="Код" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiFillPage_Click" Content="Контекст" />
                            <Button Margin="0,0,5,5" Style="{StaticResource GlassButton}" Click="AiOpenFull_Click" Content="Во вкладке" />
                        </WrapPanel>

                        <Border Grid.Row="3" Background="{DynamicResource ContentSurfaceBrush}"
                                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                                CornerRadius="{DynamicResource ControlCornerRadius}" ClipToBounds="True">
                            <wv2:WebView2 x:Name="AiWebView" />
                        </Border>
                        <TextBlock x:Name="AiStatus" Grid.Row="4" Margin="4,8,4,1"
                                   MaxHeight="36" Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                   Text="Выберите сервис и введите запрос" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
