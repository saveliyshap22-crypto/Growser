<Window x:Class="Chroma.Browser.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки Chroma Browser"
        Width="1020"
        Height="790"
        MinWidth="840"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="Настройки Chroma" />
                <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource MutedTextBrush}"
                           Text="Форма, материал, курсор, вкладки, медиапанель, AI и приватность" />
            </StackPanel>
            <Border x:Name="AccentPreview" Grid.Column="1" Width="104" Height="48" Margin="16,0,0,0"
                    CornerRadius="{DynamicResource TabCornerRadius}" Background="{DynamicResource AccentBrush}"
                    BorderBrush="{DynamicResource AccentMediumBrush}" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource AccentForegroundBrush}" FontWeight="Bold" Text="Chroma" />
                    <TextBlock FontSize="9" Foreground="{DynamicResource AccentForegroundBrush}" Opacity="0.72" Text="предпросмотр" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="1" TabStripPlacement="Left" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource DividerBrush}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Width" Value="182" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                </Style>
            </TabControl.Resources>

            <TabItem Header="Внешний вид">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Тема и плотность" />
                                <UniformGrid Margin="0,14,0,0" Columns="2">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Margin="0,0,0,5" Text="Тема" />
                                        <ComboBox x:Name="ThemeBox" DisplayMemberPath="Name" />
                                    </StackPanel>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Margin="0,0,0,5" Text="Плотность" />
                                        <ComboBox x:Name="DensityBox" DisplayMemberPath="Name" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Акцентный цвет" />
                                <TextBlock Margin="0,6,0,12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Цвет применяется к вкладкам, кнопкам, фокусу, меню, AI, медиапанели и новой вкладке." />
                                <ListBox x:Name="AccentPalette" SelectionChanged="AccentPalette_SelectionChanged"
                                         HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Padding="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0,0,8,8" />
                                            <Setter Property="Padding" Value="4" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Ring" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="{DynamicResource PillCornerRadius}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Ring" Property="Background" Value="{DynamicResource GlassHoverBrush}" /></Trigger>
                                                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Ring" Property="BorderBrush" Value="{DynamicResource TextBrush}" /><Setter TargetName="Ring" Property="Background" Value="{DynamicResource AccentSoftBrush}" /></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBoxItem Tag="#FF8A3D" ToolTip="Оранжевый"><Border Width="42" Height="42" CornerRadius="21" Background="#FF8A3D" /></ListBoxItem>
                                    <ListBoxItem Tag="#FFB020" ToolTip="Янтарный"><Border Width="42" Height="42" CornerRadius="21" Background="#FFB020" /></ListBoxItem>
                                    <ListBoxItem Tag="#FF5C72" ToolTip="Коралловый"><Border Width="42" Height="42" CornerRadius="21" Background="#FF5C72" /></ListBoxItem>
                                    <ListBoxItem Tag="#E96BCE" ToolTip="Розовый"><Border Width="42" Height="42" CornerRadius="21" Background="#E96BCE" /></ListBoxItem>
                                    <ListBoxItem Tag="#A983FF" ToolTip="Фиолетовый"><Border Width="42" Height="42" CornerRadius="21" Background="#A983FF" /></ListBoxItem>
                                    <ListBoxItem Tag="#748BFF" ToolTip="Индиго"><Border Width="42" Height="42" CornerRadius="21" Background="#748BFF" /></ListBoxItem>
                                    <ListBoxItem Tag="#58A6FF" ToolTip="Синий"><Border Width="42" Height="42" CornerRadius="21" Background="#58A6FF" /></ListBoxItem>
                                    <ListBoxItem Tag="#32C7D9" ToolTip="Бирюзовый"><Border Width="42" Height="42" CornerRadius="21" Background="#32C7D9" /></ListBoxItem>
                                    <ListBoxItem Tag="#53D6A5" ToolTip="Мятный"><Border Width="42" Height="42" CornerRadius="21" Background="#53D6A5" /></ListBoxItem>
                                    <ListBoxItem Tag="#A7D65B" ToolTip="Лаймовый"><Border Width="42" Height="42" CornerRadius="21" Background="#A7D65B" /></ListBoxItem>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock FontSize="19" FontWeight="SemiBold" Text="Форма и материал" />
                                    <Button DockPanel.Dock="Right" Style="{StaticResource GlassButton}" Click="ResetAppearance_Click" Content="Сбросить" />
                                </DockPanel>
                                <UniformGrid Margin="0,14,0,4" Columns="2">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Margin="0,0,0,5" Text="Форма элементов" />
                                        <ComboBox x:Name="ShapeBox" DisplayMemberPath="Name" SelectionChanged="AppearanceMode_Changed" />
                                    </StackPanel>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Margin="0,0,0,5" Text="Материал поверхностей" />
                                        <ComboBox x:Name="GlassModeBox" DisplayMemberPath="Name" SelectionChanged="AppearanceMode_Changed" />
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Margin="0,6,0,12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Квадратный режим уменьшает скругления во всём браузере. «Без стекла» делает поверхности непрозрачными и отключает стеклянные блики." />
                                <DockPanel Margin="0,3,0,3">
                                    <TextBlock Text="Сила стекла" />
                                    <TextBlock x:Name="GlassValueText" DockPanel.Dock="Right" Foreground="{DynamicResource AccentTextBrush}" />
                                </DockPanel>
                                <Slider x:Name="GlassSlider" Minimum="0.35" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="AppearanceSlider_ValueChanged" />
                                <DockPanel Margin="0,10,0,3">
                                    <TextBlock Text="Прозрачность окна" />
                                    <TextBlock x:Name="OpacityValueText" DockPanel.Dock="Right" Foreground="{DynamicResource AccentTextBrush}" />
                                </DockPanel>
                                <Slider x:Name="OpacitySlider" Minimum="0.84" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="AppearanceSlider_ValueChanged" />
                                <DockPanel Margin="0,10,0,3">
                                    <TextBlock Text="Пользовательское скругление" />
                                    <TextBlock x:Name="CornerValueText" DockPanel.Dock="Right" Foreground="{DynamicResource AccentTextBrush}" />
                                </DockPanel>
                                <Slider x:Name="CornerSlider" Minimum="0" Maximum="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="AppearanceSlider_ValueChanged" />
                                <CheckBox x:Name="MicaCheck" Margin="0,14,0,0" Content="Использовать системный Mica в Windows 11" />
                                <CheckBox x:Name="AmbientGlowCheck" Content="Фоновые цветные блики на новой вкладке" />
                                <CheckBox x:Name="ReduceMotionCheck" Content="Отключить большинство анимаций" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Курсор" />
                                <TextBlock Margin="0,6,0,12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Можно оставить системную стрелку или использовать точку. Стиль применяется и к интерфейсу, и к страницам WebView2." />
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="92" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,5" Text="Стиль курсора" />
                                        <ComboBox x:Name="CursorStyleBox" DisplayMemberPath="Name" SelectionChanged="CursorStyle_Changed" />
                                        <DockPanel Margin="0,12,0,3">
                                            <TextBlock Text="Размер точки" />
                                            <TextBlock x:Name="CursorSizeValueText" DockPanel.Dock="Right" Foreground="{DynamicResource AccentTextBrush}" />
                                        </DockPanel>
                                        <Slider x:Name="CursorSizeSlider" Minimum="10" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="CursorSizeSlider_ValueChanged" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="72" Height="72" Margin="18,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{DynamicResource ContentSurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1" CornerRadius="{DynamicResource ControlCornerRadius}">
                                        <Ellipse x:Name="CursorPreviewDot" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Fill="White" Stroke="Black" StrokeThickness="2" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Новая вкладка" />
                                <CheckBox x:Name="MediaPillCheck" Margin="0,12,0,4"
                                          Content="Показывать медиапанель слева от вкладок, когда играет музыка или видео" />
                                <TextBlock Margin="0,2,0,12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Медиапанель показывает название, сайт, паузу и звук. Её можно полностью отключить." />
                                <TextBlock Margin="0,0,0,5" Text="Обои новой вкладки" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource GlassButton}" Click="BrowseWallpaper_Click" Content="Выбрать" />
                                    <TextBox x:Name="WallpaperBox" Style="{StaticResource GlassTextBox}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Вкладки и память">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Вкладки" />
                                <TextBlock Margin="0,14,0,5" Text="Ширина вкладок" />
                                <ComboBox x:Name="TabWidthBox" Width="320" HorizontalAlignment="Left" DisplayMemberPath="Name" />
                                <CheckBox x:Name="ShowTabCloseButtonsCheck" Margin="0,12,0,0" Content="Показывать кнопку закрытия, когда хватает места" />
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Вкладки сжимаются до безопасной ширины, длинные заголовки обрезаются, а список всех вкладок всегда доступен отдельной кнопкой." />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Сеанс и память" />
                                <CheckBox x:Name="RestoreSessionCheck" Margin="0,14,0,0" Content="Восстанавливать прошлый сеанс" />
                                <CheckBox x:Name="SuspendTabsCheck" Content="Приостанавливать фоновые вкладки" />
                                <TextBlock Margin="0,14,0,5" Text="Приостанавливать после, минут" />
                                <TextBox x:Name="SuspendMinutesBox" Width="130" HorizontalAlignment="Left" Style="{StaticResource GlassTextBox}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Приватность">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Конфиденциальность и защита" />
                                <CheckBox x:Name="HttpsFirstCheck" Margin="0,14,0,0" Content="HTTPS First для введённых адресов" />
                                <CheckBox x:Name="AdBlockCheck" Content="Встроенная блокировка рекламы и трекеров" />
                                <CheckBox x:Name="TrackingCheck" Content="Строгая защита Chromium от отслеживания" />
                                <CheckBox x:Name="EnhancedSecurityCheck" Content="Усиленный режим безопасности" />
                                <CheckBox x:Name="ClearOnExitCheck" Content="Очищать данные просмотра при выходе" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Пароли и формы" />
                                <CheckBox x:Name="PasswordAutosaveCheck" Margin="0,14,0,0" Content="Предлагать сохранять пароли" />
                                <CheckBox x:Name="AutofillCheck" Content="Автозаполнение форм" />
                                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Хранилище Chroma шифруется Windows DPAPI и открывается после проверки Windows Hello." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Поиск и AI">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Поиск" />
                                <TextBlock Margin="0,14,0,5" Text="Поисковая система" />
                                <ComboBox x:Name="SearchEngineBox" Width="300" HorizontalAlignment="Left" DisplayMemberPath="Name" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="AI-панель" />
                                <TextBlock Margin="0,14,0,5" Text="Сервис по умолчанию" />
                                <ComboBox x:Name="AiProviderBox" Width="300" HorizontalAlignment="Left" DisplayMemberPath="Name" />
                                <CheckBox x:Name="AiIncludePageContextCheck" Margin="0,12,0,0" Content="По умолчанию добавлять текст текущей страницы" />
                                <TextBlock Margin="0,13,0,5" Text="Максимальный объём контекста" />
                                <ComboBox x:Name="AiContextLimitBox" Width="300" HorizontalAlignment="Left" DisplayMemberPath="Name" />
                                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Chroma вставляет подготовленный запрос в официальный веб-интерфейс сервиса. Отправка остаётся под вашим контролем." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Загрузки и система">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Загрузки" />
                                <TextBlock Margin="0,14,0,5" Text="Папка сохранения" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource GlassButton}" Click="BrowseDownloads_Click" Content="Выбрать" />
                                    <TextBox x:Name="DownloadFolderBox" Style="{StaticResource GlassTextBox}" />
                                </DockPanel>
                                <CheckBox x:Name="AskDownloadCheck" Margin="0,12,0,0" Content="Всегда спрашивать место сохранения" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock FontSize="19" FontWeight="SemiBold" Text="Обновления" />
                                <CheckBox x:Name="AutoUpdateCheck" Margin="0,14,0,0" Content="Автоматически проверять обновления" />
                                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"
                                           Text="Перед запуском обновления Chroma сверяет опубликованную SHA-256 контрольную сумму установщика." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="112" Margin="0,0,8,0" Style="{StaticResource GlassButton}" Click="Cancel_Click" Content="Отмена" />
            <Button Width="150" Style="{StaticResource AccentButton}" Click="Save_Click" Content="Сохранить" />
        </StackPanel>
    </Grid>
</Window>
