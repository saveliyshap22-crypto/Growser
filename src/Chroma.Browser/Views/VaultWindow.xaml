<Window x:Class="Chroma.Browser.Views.VaultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пароли Chroma Browser"
        Width="820"
        Height="570"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="28" FontWeight="SemiBold" Text="Пароли" />
        <DataGrid x:Name="VaultGrid" Grid.Row="1" Margin="0,14,0,14" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" SelectionChanged="VaultGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сайт" Binding="{Binding Origin}" Width="2*" />
                <DataGridTextColumn Header="Пользователь" Binding="{Binding Username}" Width="2*" />
                <DataGridTextColumn Header="Изменён" Binding="{Binding UpdatedAt, StringFormat={}{0:g}}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="OriginBox" Margin="0,0,7,0" Style="{StaticResource GlassTextBox}" ToolTip="Сайт" />
            <TextBox x:Name="UsernameBox" Grid.Column="1" Margin="0,0,7,0" Style="{StaticResource GlassTextBox}" ToolTip="Логин" />
            <PasswordBox x:Name="PasswordBox" Grid.Column="2" Padding="12,8" Background="{StaticResource GlassBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="#40FFFFFF" ToolTip="Пароль" />
        </Grid>
        <StackPanel Grid.Row="3" Margin="0,12,0,0" Orientation="Horizontal">
            <Button Margin="0,0,7,0" Style="{StaticResource GlassButton}" Click="Save_Click" Content="Добавить / сохранить" />
            <Button Margin="0,0,7,0" Style="{StaticResource GlassButton}" Click="Copy_Click" Content="Копировать пароль" />
            <Button Style="{StaticResource GlassButton}" Click="Delete_Click" Content="Удалить" />
        </StackPanel>
    </Grid>
</Window>

