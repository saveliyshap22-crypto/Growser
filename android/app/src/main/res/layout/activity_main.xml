<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/window_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/browserShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/chroma_icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:text="Chroma"
                android:textColor="@color/chroma_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/privateBadge"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/glass_button"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/private_mode"
                android:textColor="@color/chroma_accent"
                android:textSize="10sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/newTabButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/glass_button"
                android:contentDescription="@string/new_tab"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="＋"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="22sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/glass_button"
                android:contentDescription="@string/back"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="‹"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="28sp" />

            <Button
                android:id="@+id/forwardButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/glass_button"
                android:contentDescription="@string/forward"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="›"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="28sp" />

            <EditText
                android:id="@+id/addressBar"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/address_surface"
                android:hint="@string/address_hint"
                android:imeOptions="actionGo"
                android:inputType="textUri|textNoSuggestions"
                android:maxLines="1"
                android:selectAllOnFocus="true"
                android:textColor="@color/chroma_text"
                android:textColorHint="@color/chroma_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/reloadButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/glass_button"
                android:contentDescription="@string/reload"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="↻"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="20sp" />

            <Button
                android:id="@+id/menuButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/glass_button"
                android:contentDescription="@string/menu"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="⋯"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="24sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/webSurface"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/web_surface"
            android:clipToOutline="true"
            android:elevation="8dp"
            android:outlineProvider="background">

            <FrameLayout
                android:id="@+id/webContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="top"
                android:max="100"
                android:progressTint="@color/chroma_accent"
                android:visibility="gone" />
        </FrameLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="7dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabBar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/glass_panel"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/homeButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="⌂\nГлавная"
                android:textAllCaps="false"
                android:textColor="@color/chroma_accent"
                android:textSize="11sp" />

            <Button
                android:id="@+id/tabsButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="▣\nВкладки"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="11sp" />

            <Button
                android:id="@+id/bookmarkButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="☆\nЗакладки"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="11sp" />

            <Button
                android:id="@+id/aiButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="AI\nПомощник"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="11sp" />

            <Button
                android:id="@+id/bottomMenuButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="☰\nМеню"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/aiSheet"
        android:layout_width="match_parent"
        android:layout_height="540dp"
        android:layout_gravity="bottom"
        android:background="@drawable/ai_surface"
        android:elevation="24dp"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="#66FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chroma AI"
                android:textColor="@color/chroma_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/aiProvider"
                android:layout_width="145dp"
                android:layout_height="40dp"
                android:background="@drawable/glass_button" />

            <Button
                android:id="@+id/aiCloseButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/glass_button"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="×"
                android:textAllCaps="false"
                android:textColor="@color/chroma_text"
                android:textSize="24sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/aiSummarize"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/glass_button"
                    android:text="Пересказать"
                    android:textAllCaps="false"
                    android:textColor="@color/chroma_text" />
                <Button
                    android:id="@+id/aiExplain"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/glass_button"
                    android:text="Объяснить"
                    android:textAllCaps="false"
                    android:textColor="@color/chroma_text" />
                <Button
                    android:id="@+id/aiTranslate"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/glass_button"
                    android:text="Перевести"
                    android:textAllCaps="false"
                    android:textColor="@color/chroma_text" />
                <Button
                    android:id="@+id/aiCode"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/glass_button"
                    android:text="Код"
                    android:textAllCaps="false"
                    android:textColor="@color/chroma_text" />
            </LinearLayout>
        </HorizontalScrollView>

        <WebView
            android:id="@+id/aiWebView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:background="#111318" />

        <TextView
            android:id="@+id/aiStatus"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="Текст страницы передаётся только после нажатия действия"
            android:textColor="@color/chroma_muted"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
