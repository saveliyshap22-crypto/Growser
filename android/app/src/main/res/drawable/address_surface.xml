<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient android:angle="135" android:startColor="#F03B3F48" android:endColor="#F020232A" />
            <stroke android:width="1.5dp" android:color="@color/chroma_accent" />
            <padding android:left="16dp" android:top="0dp" android:right="16dp" android:bottom="0dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient android:angle="135" android:startColor="#D632363E" android:endColor="#D01F2228" />
            <stroke android:width="1dp" android:color="@color/chroma_divider" />
            <padding android:left="16dp" android:top="0dp" android:right="16dp" android:bottom="0dp" />
        </shape>
    </item>
</selector>
